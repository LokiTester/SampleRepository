Option Explicit

Const BASE_URL As String = "https://almoctane-eur.saas.microfocus.com"
Const PROXY_URL As String = "ncproxy:8080"
Const PROXY_USER As String = "UID"
Const PROXY_PASS As String = "password"

Const CLIENT_ID As String = "ITT_AP1064tegrationn16a75mmmq9vj5"
Const CLIENT_SECRET As String = "4yYF0cdAo"

Dim http As Object


' 🔁 MAIN FUNCTION
Sub Fetch_Octane_Data()

    Set http = CreateObject("WinHttp.WinHttpRequest.5.1")
    
    ' Enable proxy
    http.SetProxy 2, PROXY_URL
    http.SetCredentials PROXY_USER, PROXY_PASS, 0
    
    ' Step 1: Login
    Call Login
    
    ' Step 2: Get Data
    Call Get_Test_Count

End Sub


' 🔐 LOGIN (SESSION CREATED INTERNALLY)
Sub Login()

    Dim url As String
    Dim body As String
    
    url = BASE_URL & "/authentication/sign_in"
    
    http.Open "POST", url, False
    http.setRequestHeader "Content-Type", "application/json"
    
    body = "{""client_id"":""" & CLIENT_ID & """,""client_secret"":""" & CLIENT_SECRET & """}"
    
    http.Send body
    
    ' Debug
    Debug.Print http.Status, http.StatusText
    
End Sub


' 📊 FETCH DATA
Sub Get_Test_Count()

    Dim url As String
    Dim response As String
    Dim totalCount As String
    
    url = BASE_URL & "/api/shared_spaces/501007/workspaces/3001/tests?limit=1&total_count=true&query=""(user_tags={id=105001})"""
    
    http.Open "GET", url, False
    
    ' Required header
    http.setRequestHeader "ALM-OCTANE-TECH-PREVIEW", "false"
    
    http.Send
    
    response = http.ResponseText
    
    totalCount = ExtractTotalCount(response)
    
    ' Output to Excel
    Sheet1.Range("A1").Value = "Automated Test Count"
    Sheet1.Range("B1").Value = totalCount
    Sheet1.Range("A2").Value = "Last Updated"
    Sheet1.Range("B2").Value = Now()

End Sub


' 🔍 PARSE total_count
Function ExtractTotalCount(response As String) As String

    Dim startPos As Long
    Dim endPos As Long
    
    startPos = InStr(response, """total_count"":") + Len("""total_count"":")
    endPos = InStr(startPos, response, ",")
    
    ExtractTotalCount = Trim(Mid(response, startPos, endPos - startPos))

End Function


' 🔁 AUTO REFRESH
Sub Start_Auto_Refresh()

    Call Fetch_Octane_Data
    
    Application.OnTime Now + TimeValue("00:05:00"), "Start_Auto_Refresh"

End Sub
